{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "incruit-jobpost.schema.json",
  "title": "인크루트 채용공고 스키마",
  "description": "인크루트 채용공고 HTML 템플릿의 구조화 데이터 스키마. HR-JSON 속성과 인크루트 필드 속성을 정의합니다.",
  "type": "object",
  "properties": {
    "sections": {
      "type": "array",
      "description": "채용공고를 구성하는 12개 HR-JSON 섹션 목록",
      "items": { "$ref": "#/definitions/section" }
    },
    "keyVisual": {
      "$ref": "#/definitions/keyVisualAiOutput",
      "description": "AI 변환 시 생성되는 키비주얼 메타데이터"
    },
    "verification": {
      "$ref": "#/definitions/verificationReport",
      "description": "변환 품질 검증 리포트"
    },
    "inputType": {
      "$ref": "#/definitions/inputType",
      "description": "입력 원문의 형식"
    },
    "confidence": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "섹션 감지 신뢰도 점수 (0-100)"
    }
  },

  "definitions": {

    "sectionId": {
      "type": "string",
      "enum": [
        "company_info",
        "recruit_title",
        "job_description",
        "qualification",
        "preferred",
        "work_condition",
        "salary",
        "benefits",
        "hiring_process",
        "deadline",
        "apply_method",
        "etc_info"
      ],
      "description": "12개 섹션 고유 식별자"
    },

    "section": {
      "type": "object",
      "description": "채용공고 섹션 정의. HTML 출력 시 <div data-hr-property='...' data-incruit-field='...'>로 래핑됩니다.",
      "required": ["id", "hrProp", "incruitField", "keywords"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/sectionId" },
        "hrProp": {
          "type": "string",
          "description": "HTML data-hr-property 속성값 (HR-JSON 스펙 프로퍼티명)"
        },
        "incruitField": {
          "type": "string",
          "description": "HTML data-incruit-field 속성값 (인크루트 내부 필드명)"
        },
        "keywords": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true,
          "description": "이 섹션을 감지하기 위한 한국어 키워드 목록"
        },
        "headerText": {
          "type": "string",
          "description": "감지된 원문 헤더 텍스트 (런타임 값)"
        },
        "contentHtml": {
          "type": "string",
          "description": "섹션 본문 HTML (런타임 값)"
        }
      }
    },

    "sectionDefinitions": {
      "description": "12개 섹션의 정적 정의 (ruleConverter.js SECTION_DEFS 원본)",
      "type": "array",
      "items": { "$ref": "#/definitions/section" },
      "const": [
        {
          "id": "company_info",
          "hrProp": "description",
          "incruitField": "company_info",
          "keywords": ["기업소개", "회사소개", "회사개요", "기업개요", "기관소개", "법인소개", "조합소개", "기관 소개", "회사 소개", "기업 소개"]
        },
        {
          "id": "recruit_title",
          "hrProp": "title",
          "incruitField": "recruit_title",
          "keywords": ["모집부문", "모집직종", "채용분야", "모집분야", "채용직무", "모집개요", "채용개요", "모집인원", "모집 부문", "채용 분야", "모집 인원"]
        },
        {
          "id": "job_description",
          "hrProp": "responsibilities",
          "incruitField": "job_description",
          "keywords": ["담당업무", "주요업무", "직무내용", "업무내용", "수행업무", "직무소개", "업무소개", "하는 일", "담당 업무", "주요 업무", "직무 내용", "업무 내용", "직무기술서"]
        },
        {
          "id": "qualification",
          "hrProp": "qualifications",
          "incruitField": "qualification",
          "keywords": ["자격요건", "지원자격", "필수자격", "필수요건", "자격조건", "응시자격", "지원요건", "자격 요건", "지원 자격", "필수 자격", "필수 요건"]
        },
        {
          "id": "preferred",
          "hrProp": "preferredQualifications",
          "incruitField": "preferred",
          "keywords": ["우대사항", "우대조건", "가점사항", "우대요건", "선호사항", "우대 사항", "우대 조건", "가점 사항"]
        },
        {
          "id": "work_condition",
          "hrProp": "jobLocation + employmentType",
          "incruitField": "work_condition",
          "keywords": ["근무조건", "근무환경", "근무형태", "근무장소", "근무지", "근무시간", "근무처", "근무 조건", "근무 환경", "근무 형태", "근무 장소", "고용형태", "고용 형태", "채용조건", "채용 조건"]
        },
        {
          "id": "salary",
          "hrProp": "baseSalary",
          "incruitField": "salary",
          "keywords": ["급여", "연봉", "보수", "임금", "급여조건", "처우", "보상", "연봉수준", "급여 조건", "처우조건", "처우 조건", "보수조건"]
        },
        {
          "id": "benefits",
          "hrProp": "jobBenefits",
          "incruitField": "benefits",
          "keywords": ["복리후생", "복지혜택", "복지제도", "사내복지", "복리 후생", "복지 혜택", "복지 제도", "사내 복지", "지원제도", "사내문화"]
        },
        {
          "id": "hiring_process",
          "hrProp": "applicationProcess",
          "incruitField": "hiring_process",
          "keywords": ["전형절차", "채용절차", "선발절차", "전형과정", "심사절차", "채용과정", "채용프로세스", "전형방법", "전형 절차", "채용 절차", "선발 절차", "채용 과정", "채용 프로세스", "전형일정"]
        },
        {
          "id": "deadline",
          "hrProp": "validThrough",
          "incruitField": "deadline",
          "keywords": ["접수기간", "마감일", "모집기간", "지원기간", "접수마감", "서류접수", "원서접수", "지원마감", "접수 기간", "모집 기간", "지원 기간", "접수 마감", "채용기간", "공고기간"]
        },
        {
          "id": "apply_method",
          "hrProp": "applicationContact",
          "incruitField": "apply_method",
          "keywords": ["접수방법", "지원방법", "지원서접수", "지원서 접수", "제출서류", "접수처", "서류제출", "지원서 제출", "접수 방법", "지원 방법", "제출 서류", "서류 제출", "지원서류"]
        },
        {
          "id": "etc_info",
          "hrProp": "additionalInfo",
          "incruitField": "etc_info",
          "keywords": ["기타안내", "참고사항", "유의사항", "기타사항", "주의사항", "비고", "안내사항", "기타 안내", "참고 사항", "유의 사항", "기타 사항", "주의 사항", "문의처", "기타문의"]
        }
      ]
    },

    "inputType": {
      "type": "string",
      "enum": ["already_incruit", "structured_html", "plain_text", "empty"],
      "description": "입력 형식 분류. already_incruit: data-hr-property 등 이미 변환됨, structured_html: HTML 태그 포함, plain_text: 순수 텍스트, empty: 빈 입력"
    },

    "conversionResult": {
      "type": "object",
      "description": "convertByRules() 함수의 반환값",
      "required": ["html", "sections", "confidence", "inputType"],
      "properties": {
        "html": {
          "type": "string",
          "description": "변환된 HTML 문자열 (data-hr-property/data-incruit-field 속성 포함)"
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sectionDef": {
                "oneOf": [
                  { "$ref": "#/definitions/section" },
                  { "type": "null" }
                ],
                "description": "매칭된 섹션 정의 (미매칭 시 null)"
              },
              "headerText": {
                "type": "string",
                "description": "감지된 헤더 텍스트"
              },
              "contentHtml": {
                "type": "string",
                "description": "섹션 본문 HTML"
              }
            }
          },
          "description": "감지된 섹션 세그먼트 배열"
        },
        "confidence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "신뢰도 점수: 섹션비율(60점) + 핵심섹션(30점) + 타이틀(10점)"
        },
        "inputType": {
          "$ref": "#/definitions/inputType"
        }
      }
    },

    "keyVisualAiOutput": {
      "type": "object",
      "description": "AI 변환 시 HTML 뒤에 ```json 블록으로 출력되는 키비주얼 메타데이터",
      "required": ["jobCode", "title", "description", "date", "companyName"],
      "additionalProperties": false,
      "properties": {
        "jobCode": {
          "type": "string",
          "description": "공고 번호",
          "examples": ["공고 제2026-123호"]
        },
        "title": {
          "type": "string",
          "description": "기업명 + 공고제목 (최대 3줄, 줄바꿈은 \\n)",
          "examples": ["인크루트\n고객만족팀 채용"]
        },
        "description": {
          "type": "string",
          "description": "회사/직무 핵심 소개 (최대 3줄, 줄바꿈은 \\n)",
          "examples": ["국내 1위 채용 플랫폼\n고객만족팀에서 함께할 인재를 찾습니다"]
        },
        "date": {
          "type": "string",
          "description": "마감일 (YYYY년 MM월 DD일 형식). 원문에 없으면 오늘 기준 2주 후",
          "pattern": "^\\d{4}년 \\d{1,2}월 \\d{1,2}일$",
          "examples": ["2026년 3월 15일"]
        },
        "companyName": {
          "type": "string",
          "description": "기업명",
          "examples": ["인크루트"]
        },
        "industry": {
          "type": "string",
          "description": "업종 키워드 (buildConversionPrompt에서만 포함, buildKvPrompt에서는 미포함)",
          "examples": ["IT", "제조", "금융", "의료", "교육"]
        }
      }
    },

    "keyVisualState": {
      "type": "object",
      "description": "state.kv 전체 구조 (콘텐츠 + 레이아웃 + 스타일)",
      "properties": {
        "jobCode": { "type": "string", "default": "공고 제2026-0호" },
        "title": { "type": "string", "default": "기업명이 들어갑니다.\n공고명이 들어갑니다.\n최대 3줄까지 가능합니다." },
        "description": { "type": "string", "default": "회사에 대한 소개가 들어갑니다.\n회사에 대한 소개가 들어갑니다.\n최대 3줄까지 가능합니다." },
        "date": { "type": "string", "default": "2026년 2월 5일" },
        "companyName": { "type": "string", "default": "기업명" },

        "templateType": {
          "type": "string",
          "enum": ["overlay", "sidebar", "banner"],
          "default": "overlay",
          "description": "KV 레이아웃 유형"
        },
        "textAlign": {
          "type": "string",
          "enum": ["left", "center", "right"],
          "default": "left"
        },
        "effect": {
          "type": "string",
          "enum": ["gradient", "blur", "solid"],
          "default": "gradient",
          "description": "배경 효과"
        },
        "heightMode": {
          "type": "string",
          "enum": ["fixed", "auto"],
          "default": "fixed"
        },
        "bgColor": { "type": "string", "default": "#1f46a8", "description": "배경색 (HEX)" },
        "brandColor": { "type": "string", "default": "#16213d", "description": "브랜드색 (HEX)" },
        "logoDataUrl": { "type": "string", "default": "", "description": "로고 이미지 Base64 Data URL" },
        "bgImageDataUrl": { "type": "string", "default": "", "description": "배경 이미지 Base64 Data URL" },
        "bgImageUrl": {
          "type": "string",
          "default": "https://images.unsplash.com/photo-1497366216548-37526070297c?w=800&q=80",
          "description": "배경 이미지 Unsplash URL"
        },

        "fieldStyles": {
          "type": "object",
          "description": "필드별 타이포그래피 설정",
          "properties": {
            "jobCode":     { "$ref": "#/definitions/fieldStyle" },
            "title":       { "$ref": "#/definitions/fieldStyle" },
            "description": { "$ref": "#/definitions/fieldStyle" },
            "dateCompany": { "$ref": "#/definitions/fieldStyle" }
          }
        },

        "textPosition": {
          "type": "object",
          "description": "필드별 위치 좌표 (px)",
          "properties": {
            "jobCode":     { "$ref": "#/definitions/fieldPosition" },
            "title":       { "$ref": "#/definitions/fieldPosition" },
            "description": { "$ref": "#/definitions/fieldPosition" },
            "dateCompany": { "$ref": "#/definitions/fieldPosition" }
          }
        }
      }
    },

    "fieldStyle": {
      "type": "object",
      "properties": {
        "fontSize": { "type": "integer", "minimum": 8, "maximum": 100, "description": "글꼴 크기 (px)" },
        "color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$", "description": "글꼴 색상 (HEX)" },
        "bold": { "type": "boolean", "description": "굵게 여부" }
      }
    },

    "fieldPosition": {
      "type": "object",
      "properties": {
        "left": { "type": "integer", "description": "왼쪽 오프셋 (px)" },
        "top": { "type": "integer", "description": "위쪽 오프셋 (px)" }
      }
    },

    "verificationReport": {
      "type": "object",
      "description": "verifyConversion() 함수의 검증 리포트",
      "required": ["passed", "textMatch", "score", "grade", "summary"],
      "properties": {
        "passed": {
          "type": "boolean",
          "description": "검증 통과 여부 (grade !== 'F')"
        },
        "textMatch": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "텍스트 일치율 (%). 문장 단위 1:1 대조, 80% 단어 부분 매칭 포함"
        },
        "missingTexts": {
          "type": "array",
          "items": { "type": "string" },
          "description": "원문에 있지만 변환 결과에서 누락된 문장 (최대 80자 + '...')"
        },
        "hallucinations": {
          "type": "array",
          "items": { "type": "string" },
          "description": "변환 결과에만 존재하는 문장 (50% 미만 단어 매칭 시 환각 판정)"
        },
        "structureCheck": {
          "type": "object",
          "description": "HTML 구조 요소 개수 비교",
          "properties": {
            "tables": {
              "type": "object",
              "properties": {
                "source": { "type": "integer" },
                "converted": { "type": "integer" }
              }
            },
            "lists": {
              "type": "object",
              "properties": {
                "source": { "type": "integer" },
                "converted": { "type": "integer" }
              }
            },
            "headings": {
              "type": "object",
              "properties": {
                "source": { "type": "integer" },
                "converted": { "type": "integer" }
              }
            }
          }
        },
        "criticalData": {
          "type": "object",
          "description": "핵심 데이터 검증 (전화번호, 이메일, 급여, 날짜, URL)",
          "properties": {
            "missing": {
              "type": "array",
              "items": { "type": "string" },
              "description": "누락된 핵심 데이터 ('타입: 값' 형식)"
            }
          }
        },
        "tableDetail": {
          "type": "object",
          "properties": {
            "cellsMissing": {
              "type": "array",
              "items": { "type": "string" },
              "description": "누락된 테이블 셀 내용 (최대 60자)"
            }
          }
        },
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "품질 점수 (100 - 감점). 감점: 텍스트미달 1점/%, 환각 5점/건, 핵심데이터 10점/건, 셀누락 3점/건, 테이블소실 20점"
        },
        "grade": {
          "type": "string",
          "enum": ["A", "B", "C", "F"],
          "description": "품질 등급. A(95+): 우수, B(80-94): 양호, C(60-79): 주의, F(0-59): 실패"
        },
        "summary": {
          "type": "string",
          "description": "한국어 검증 요약 메시지"
        }
      }
    },

    "industryCategory": {
      "type": "object",
      "description": "업종별 배경 이미지 및 감지 규칙 (17개 카테고리)",
      "properties": {
        "key": {
          "type": "string",
          "enum": ["ai", "data", "dev", "it", "design", "marketing", "finance", "medical", "bio", "education", "manufacturing", "construction", "logistics", "retail", "hr", "service", "business", "office"],
          "description": "업종 키"
        },
        "detectionPattern": {
          "type": "string",
          "description": "감지 정규식 패턴 (한국어 + 영어)"
        },
        "bgImageUrl": {
          "type": "string",
          "format": "uri",
          "description": "Unsplash 배경 이미지 URL"
        },
        "searchKeywords": {
          "type": "string",
          "description": "영어 검색 키워드"
        }
      }
    },

    "industryDefinitions": {
      "description": "17개 업종 카테고리의 정적 정의 (app.js KV_BG_IMAGES + pickBgImageByKeywords 원본)",
      "type": "array",
      "items": { "$ref": "#/definitions/industryCategory" },
      "const": [
        { "key": "ai", "detectionPattern": "ai|인공지능|머신러닝|딥러닝|llm", "searchKeywords": "artificial intelligence technology" },
